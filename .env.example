# ===========================================
# GreenLedger — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# --- Database (Required) ---
# Supabase PostgreSQL connection string
# Find this in: Supabase Dashboard → Settings → Database → Connection string → URI
# Use the "Transaction" pooler connection string for serverless (Vercel)
DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- OpenAI (Required for report generation) ---
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Optional ---
# OpenAI model to use (default: gpt-4o)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# Server port (default: 3000, Vercel sets this automatically)
PORT=3000

# Node environment
NODE_ENV=production
